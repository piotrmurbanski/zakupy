POSTGRES_DB=zakupy
POSTGRES_USER=zakupy
POSTGRES_PASSWORD=replace-with-strong-password

DATABASE_URL=postgresql://zakupy:replace-with-strong-password@postgres:5432/zakupy
JWT_SECRET=replace-with-long-random-secret

BACKEND_IMAGE=ghcr.io/REPLACE_WITH_GITHUB_OWNER/zakupy-backend:latest

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=replace-with-gmail-app-password
SMTP_FROM=your-account@gmail.com

CADDY_HTTP_PORT=80
