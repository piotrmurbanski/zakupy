COMPOSE_PROJECT_NAME=zakupy-dev
POSTGRES_DB=zakupy_dev
POSTGRES_USER=zakupy_dev
POSTGRES_PASSWORD=replace-with-strong-password

DATABASE_URL=postgresql://zakupy_dev:replace-with-strong-password@postgres:5432/zakupy_dev
JWT_SECRET=replace-with-long-random-secret

BACKEND_IMAGE=ghcr.io/REPLACE_WITH_GITHUB_OWNER/zakupy-backend:dev

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=replace-with-gmail-app-password
SMTP_FROM=your-account@gmail.com
