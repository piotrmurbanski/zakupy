COMPOSE_PROJECT_NAME=zakupy-prod
POSTGRES_DB=zakupy_prod
POSTGRES_USER=zakupy_prod
POSTGRES_PASSWORD=replace-with-strong-password

DATABASE_URL=postgresql://zakupy_prod:replace-with-strong-password@postgres:5432/zakupy_prod
JWT_SECRET=replace-with-long-random-secret

BACKEND_IMAGE=ghcr.io/REPLACE_WITH_GITHUB_OWNER/zakupy-backend:stable

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=replace-with-gmail-app-password
SMTP_FROM=your-account@gmail.com
