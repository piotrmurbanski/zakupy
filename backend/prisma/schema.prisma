generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  displayName       String           @map("display_name")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  ownedLists        ShoppingList[]
  archivedLists     ShoppingList[]   @relation("archived_lists")
  memberships       ListMember[]
  createdItems      ListItem[]
  itemSuggestions   ItemSuggestion[]
  authSessions      AuthSession[]
  claimedInvites    ListInvitation[] @relation("claimed_invitations")
  sentInvitations   ListInvitation[] @relation("sent_invitations")

  @@map("users")
}

model AuthCode {
  id           String   @id @default(cuid())
  email        String
  codeHash     String   @map("code_hash")
  expiresAt    DateTime @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  attemptCount Int      @default(0) @map("attempt_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email, createdAt(sort: Desc)])
  @@map("auth_codes")
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  deviceLabel String?  @map("device_label")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model ShoppingList {
  id          String       @id @default(cuid())
  name        String
  plannedFor  DateTime?    @map("planned_for")
  ownerUserId String       @map("owner_user_id")
  archivedByUserId String? @map("archived_by_user_id")
  archivedAt  DateTime?    @map("archived_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  owner       User         @relation(fields: [ownerUserId], references: [id])
  archivedByUser User?     @relation("archived_lists", fields: [archivedByUserId], references: [id], onDelete: SetNull)
  members     ListMember[]
  items       ListItem[]
  invitations ListInvitation[]

  @@map("shopping_lists")
}

model ListMember {
  id        String       @id @default(cuid())
  listId    String       @map("list_id")
  userId    String       @map("user_id")
  role      ListRole
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@map("list_members")
}

model ListInvitation {
  id              String    @id @default(cuid())
  listId          String    @map("list_id")
  email           String
  role            ListRole
  invitedByUserId String    @map("invited_by_user_id")
  claimedByUserId String?   @map("claimed_by_user_id")
  claimedAt       DateTime? @map("claimed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  list            ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  invitedByUser   User      @relation("sent_invitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  claimedByUser   User?     @relation("claimed_invitations", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@unique([listId, email])
  @@index([email, claimedAt])
  @@map("list_invitations")
}

model ListItem {
  id              String       @id @default(cuid())
  listId          String       @map("list_id")
  name            String
  quantity        Int          @default(1)
  comment         String?
  isChecked       Boolean      @default(false) @map("is_checked")
  iconKey         String       @default("default") @map("icon_key")
  sortOrder       Int          @default(0) @map("sort_order")
  createdByUserId String       @map("created_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  list            ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdByUser   User         @relation(fields: [createdByUserId], references: [id])

  @@map("list_items")
}

model ItemSuggestion {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  name              String
  normalizedName    String   @map("normalized_name")
  comment           String?
  normalizedComment String   @default("") @map("normalized_comment")
  iconKey           String   @default("default") @map("icon_key")
  usageCount        Int      @default(1) @map("usage_count")
  lastUsedAt        DateTime @default(now()) @map("last_used_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName, normalizedComment])
  @@index([userId, usageCount, lastUsedAt])
  @@map("item_suggestions")
}

enum ListRole {
  owner
  editor
}
